# ─────────────────────────────────────────
#  ÉLITE MOTORS — Environment Variables
# ─────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Admin Panel Security
ADMIN_PASSWORD=change_this_admin_password
SESSION_SECRET=replace_with_a_long_random_session_secret

# Email (Nodemailer — use Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=ÉLITE MOTORS <your@gmail.com>

# Dealer notification email
DEALER_EMAIL=dealer@elitemotors.com

# DB path
DB_PATH=./db/elite_motors.db
